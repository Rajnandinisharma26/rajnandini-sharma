#include<iostream>
using namespace std;

//problem 1;
//function overriding
//same function name--same parameters-- different classes;
class Appliance{
public:
    virtual void turnOn(){
        cout<< "Appliance is getting turn on...."<<"\n";
    }
    virtual void work()=0;//this is pure virtual function 
};

class Fan : public Appliance{
public:
    void turnOn() override{
        cout<<"Fan blades are moving slowly..."<<"\n";
    }
    void work() override {
        cout<<"once fan starts at full speed it gives cool air.."<<"\n";
    }
};

class Toaster : public Appliance{
public:
    void work() override{
        cout<<"toadter is heating up the breads..."<<"\n";
    }
};

int main(){
    Fan myfan;
    Appliance*kitchenApp;
    kitchenApp=&myfan;
    kitchenApp->turnOn();
    kitchenApp->work();
    
    Toaster mytoast;
    kitchenApp=&mytoast;
    kitchenApp->turnOn();
    kitchenApp->work();
    
}
