//problem 6 
// print mirror of right  angle triangle
#include<iostream>
using namespace std;

int main(){
    int n;
    
    for(int i=1;i<=5;i++){
        for(int j=5-i;j>=1;j--){
            cout<<" ";
        } 
        for(int k=1;k<=i;k++){
            cout<< "*";
        }
        cout<< "\n";
    }
}

