//problem 5
//swapping of 2 variables value using pointers and using  functions
#include<iostream>
using namespace std;

void swap(int *a,int *b){
    int temp;
    temp=*a;
    *a=*b;
    *b=temp;
}
int main(){
    int x=10, y = 20;
    
    swap(&x,&y);
    
    cout<<"after swap:\n";
    cout<<"x ="<< x <<"\n";
    cout<<"y = "<<y;
}

