//problem 1.3 
//types of inheritance
// hierarchical inheritance

class vehical{
public:
    void start(){
    cout<<"vehical starts..."<<"\n";
    }
};

class bike : public vehical{
public:
    void drive(){
    cout<<"bike is running.."<<"\n";
    }
};

class car: public vehical{
public:
    void drive(){
        cout<< "car is running..."<<"\n";
    }
};

int main(){
    car c;
    bike b;
    c.start();
    c.drive();
    b.start();
    b.drive();
}

