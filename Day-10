#include<iostream>
using namespace std;

//problem 2


int main(){
    int arr[2][2];
    
    for(int i=0;i<2;i++){
        for(int j =0;j<2;j++){
            cin>>arr[i][j];
        }
    }
    cout<<"here is your 2D array"<<"\n";
    for(int i=0;i<2;i++){
        for(int j =0;j<2;j++){
            cout<<arr[i][j]<<" ";
        }
        cout<<"\n";
    }
    return 0;
}
